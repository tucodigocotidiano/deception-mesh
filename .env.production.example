COMPOSE_PROJECT_NAME=deceptionmesh

# Para primeras pruebas en la VPS, usa imágenes locales construidas con build_local_images.sh
CONTROL_PLANE_IMAGE=deceptionmesh-control-plane:local
SENSOR_AGENT_IMAGE=deceptionmesh-sensor-agent:local

POSTGRES_DB=deception_mesh
POSTGRES_USER=deception
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD_LARGA

JWT_SECRET=CAMBIA_ESTE_SECRETO_JWT_SUPER_LARGO
SENSOR_TOKEN_PEPPER=CAMBIA_ESTE_SENSOR_TOKEN_PEPPER_SUPER_LARGO

JWT_TTL_SECONDS=3600
SENSOR_ENROLL_TTL_SECONDS=3600
SENSOR_OFFLINE_AFTER_SECONDS=300

SEVERITY_REPEAT_WINDOW_SECONDS=600
SEVERITY_MEDIUM_THRESHOLD=3
SEVERITY_HIGH_THRESHOLD=5
SEVERITY_CRITICAL_THRESHOLD=10
SEVERITY_DECOY_LEVEL=high
SEVERITY_CREDENTIAL_DECOY_LEVEL=critical

WEBHOOK_TIMEOUT_SECONDS=5
WEBHOOK_RETRY_MAX_ATTEMPTS=4
WEBHOOK_RETRY_BASE_DELAY_SECONDS=2
WEBHOOK_RETRY_MAX_DELAY_SECONDS=60
WEBHOOK_RETRY_POLL_INTERVAL_MILLIS=500

CONTROL_PLANE_HOST_PORT=18080
SENSOR_SSH_PORT=2222
SENSOR_HTTP_PORT=8081
SENSOR_HTTPS_PORT=8443

# En la mayoría de despliegues docker-compose internos basta con esto:
# SENSOR_CONTROL_PLANE_BASE_URL=http://control_plane:8080
# En Docker Desktop/WSL, si hubiera problemas de resolución interna, puedes probar:
# SENSOR_CONTROL_PLANE_BASE_URL=http://host.docker.internal:18080

CONTROL_PLANE_LOG_LEVEL=info
SENSOR_LOG_LEVEL=info
